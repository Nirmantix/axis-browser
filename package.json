{
  "name": "chrome-devtools-axi",
  "version": "0.1.15",
  "description": "Axis Browser: fast, token-efficient Chrome automation for shared CDP workflows",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nirmantix/axis-browser.git"
  },
  "homepage": "https://github.com/Nirmantix/axis-browser#readme",
  "bugs": {
    "url": "https://github.com/Nirmantix/axis-browser/issues"
  },
  "keywords": [
    "chrome",
    "devtools",
    "browser",
    "cli",
    "agent",
    "axi",
    "axis-browser",
    "toon",
    "mcp"
  ],
  "bin": {
    "chrome-devtools-axi": "dist/bin/chrome-devtools-axi.js",
    "axis-browser": "dist/bin/chrome-devtools-axi.js",
    "axib": "dist/bin/chrome-devtools-axi.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');try{fs.chmodSync('dist/bin/chrome-devtools-axi.js',0o755)}catch(e){if(!e||e.code!=='ENOENT')throw e}\"",
    "dev": "tsx bin/chrome-devtools-axi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@toon-format/toon": "^2.1.0",
    "axi-sdk-js": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
